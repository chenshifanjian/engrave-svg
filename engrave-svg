    if not check_potrace():
        missing.append("potrace")
    if not check_pillow():
        missing.append("python-pillow")

    if missing:
        print(f"错误: 缺少依赖: {', '.join(missing)}")
        print("  Arch Linux: sudo pacman -S " + " ".join(
            "potrace" if p == "potrace" else "python-pillow" for p in missing
        ))
        sys.exit(1)

    if len(sys.argv) > 1:
        main_cli()
    else:
        main_gui()
